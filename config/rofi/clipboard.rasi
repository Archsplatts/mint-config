@theme "catppuccin-default"

* {
    background-color:	transparent;
	margin:     		0px;
    padding:    		0px;
    spacing:    		0px;  
    text-color:        	@text;
}

configuration {
	columns: 2;
    show-icons: true;             
    font: "UbuntuNerd Font Medium 12";               
   
}

dmenu {
	display-name: "Clipboard";
}

window {
	background-color:  	rgba(30, 30, 46, 0.90);
	transparency:		"real";
    width: 600px;
    location: center;
 	border:           	3px;
	border-color:		@blue;
    border-radius:  	8px;  
    padding:          	14px; 
}


mainbox {
    padding:    14px;
    children: [inputbar, mode-switcher, listview]; 
    spacing: 5px; 
}

inputbar {
    background-color:  	@base;
    border-radius:  	10px;
	children:   		[ prompt, entry ];
	padding:    		8px 16px;
    spacing:    		8px;   
    enabled: true;
}

prompt {
	enabled: true;
    text-color: #cdd6f4;
}

entry {
    placeholder:        "Rechercher...";
    placeholder-color:	 @overlay0;
   
}

message {
	background-color:   transparent; 
	border-color:       transparent;
    border-radius:      16px;
 	margin:             12px 0 0; 

}

textbox {
    padding:    8px 24px;
    text-color:	@text;
     
}

listview {
    lines: 10;
    columns: 1;
    background-color: transparent;
    scrollbar:    		false; 
    border: 0px;
}

element {
    padding: 10px;
    background-color: inherit;
}

element selected  normal, element selected active {
    background-color: inherit;
    text-color: @blue;
}   

element normal normal {
    background-color:	transparent;
    text-color: 		@text;
}

element alternate normal {
    background-color:	transparent;
    text-color:			@text;
}
