@import "themes/catppuccin-default"

configuration {
    font: "UbuntuNerd Font 15";  
}

window {
	border:           	3px;
	border-color:		@blue;
	modi: 				"drun,run";
	show-icons: 		true;
	icon-theme: 		"Papirus";
	background-color:  	rgba(30, 30, 46, 0.90);
	transparency:		"real";
	border-radius:	  	8px;
    padding:          	14;
    width:            	17%; 
}

mainbox {
    enabled:            true;
    spacing:            14px;
    margin:             0px;
    padding:            14px;
    border-radius:      0px;
    border-color:       @selected;
    background-color:	transparent;
    children:           [ "listview" ];
}

listview {
	border: 	0; 
	columns:  	1;
	flow: 		vertical;
    lines:    	5;
	scrollbar:	false;  
    spacing:  	14px;         
}

inputbar {
    enabled: false;
}   

element {
	background-color:  	inherit;
	padding:			10;
	spacing:			10;
	text-color: 		@text;
}

element normal normal {
    background-color:	transparent;
    text-color: 		@text;
}

element alternate normal {
	background-color:   transparent;
    text-color: 		@text;
}

element selected normal, element selected active {  
	background-color: 	inherit;
    border-radius: 		8px;    
    text-color:        	@blue;
}

element-text {
  	background-color:	inherit;
	text-color: 		inherit;
	/*horizontal-align: 0.5;
	text-align:center;*/
}
element-icon {
    size: 35px;
}
