{
	"layer": "top",
	"position": "top",
	"height": 32,
	"width": 1280,
 	"margin-left": 8, 
	"margin-right": 8,
	//"margin-top": 4,
	"spacing": 8,
	
	"modules-left": [ "custom/updates", "clock", "sway/window" ],

	"modules-center": [ "sway/workspaces" ],
	
	"modules-right": ["pulseaudio", "tray", "custom/power" ],

    "custom/updates": {
		"exec": "$HOME/.config/waybar/scripts/dnf-status",
		"interval": 21600,
		"return-type": "json",
    	"format":"{icon}",
	  	"format-icons": {
    		"update": "",
    		"ok": "",
    		"default": ""
    	},  
		"signal": 1,
    	"on-click": "$HOME/.config/rofi/scripts/system-menu",
    	"tooltip": true,
    },

	"sway/workspaces": {
		"disable-scroll": true,
		"persistent-workspaces": {
        "1": [],
        "2": [],
        "3": []     
    },
	 "format": "{icon}",
     "format-icons": {
        "1": "",
        "2": "",
        "3": "",
        "focused": "󰮯",
        "default": ""
     }
	},

	"sway/window": {
		"max-length":35,
		"rewrite": {
			"foot": "Terminal",
			"cava": ""
		}
	},

	"clock": {
		"locale": "fr_FR.UTF-8",
		"format": "󰥔  {:%H:%M}",
		"tooltip-format": "{calendar}",
		"tooltip-delay": 0, 
	          "calendar": {
	              "mode": "month",
	              "on-scroll": 1,
	              "format": {
	                  "months": "<span color='#cba6f7'><b>{}</b></span>",
	                  "days": "<span color='#cdd6f4'><b>{}</b></span>",
	  	              "weekdays": "<span color='#f9e2af'><b>{}</b></span>",
	                  "today": "<span color='#f5e0dc'><b><u>{}</u></b></span>",
	          },
	    },
		"interval": 60,
		"timezone": "Europe/Paris",
		"on-click": "foot calcurse",
	},    

	"pulseaudio": {
    	"format": "{icon}",
    	"format-bluetooth": "{icon}",
    	"format-muted": "󰕿",
    	"format-icons": {
        	"alsa_output.pci-0000_00_1f.3.analog-stereo": "",
        	"alsa_output.pci-0000_00_1f.3.analog-stereo-muted": "",
        	"headphone": "󰋋",
        	"hands-free": "",
        	"headset": "",
        	"phone": "",
        	"phone-muted": "",
        	"portable": "",
        	"car": "",
        	"default": ["󰖀", "󰕾"]
    },
    "scroll-step": 1,
    "on-click": "pavucontrol",
    "ignored-sinks": ["Easy Effects Sink"]
	},

   	"tray": {
    	"icon-size": 20,
    	"spacing": 8,
    },

	"custom/power": {
		"format": "",
		"icon-size": 19,
		"on-click": "$HOME/.config/rofi/scripts/powermenu",
		"tooltip-format": "Power Menu"
	}
}
